<section class="card stack">
    <div class="section-head">
        <div>
            <h2>Results</h2>
            <p>Readable snippets, ranked within the selected project.</p>
        </div>
        @if (Response is not null)
        {
            <div class="section-head-actions">
                <span class="status-pill status-pill-neutral">@Response.Mode</span>
                <span class="status-pill">@Response.Results.Count result(s)</span>
            </div>
        }
    </div>

    @if (Response is null)
    {
        <p class="empty-state">Run a search to see results.</p>
    }
    else if (Response.Results.Count == 0)
    {
        <p class="empty-state">No results were found for the selected project and query.</p>
    }
    else
    {
        <div class="result-list">
            @foreach (var result in Response.Results)
            {
                <article class="result-card">
                    <div class="result-head">
                        <div class="result-title">
                            <strong class="mono">@result.RelativeFilePath</strong>
                            <p class="result-meta">Lines @result.StartLine-@result.EndLine</p>
                        </div>
                        <div class="result-badges">
                            <span class="status-pill status-pill-neutral">@result.MatchType</span>
                            <span class="status-pill">Score @result.Score.ToString("0.000")</span>
                        </div>
                    </div>
                    <pre class="snippet-block"><code>@result.Snippet</code></pre>
                </article>
            }
        </div>
    }
</section>

@code {
    [Parameter]
    public SearchResponse? Response { get; set; }
}
