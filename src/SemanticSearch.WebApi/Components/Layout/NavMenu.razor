@namespace SemanticSearch.WebApi.Components.Layout

<nav class="nav-icon-strip">
    <a href="/" class="nav-strip-home" title="Dashboard">DC</a>

    <div class="nav-strip-groups">
        @foreach (var group in PhaseGroups)
        {
            var isOpen = _openGroupName == group.Name;
            <button class="nav-strip-btn @(isOpen ? "nav-strip-btn-active" : string.Empty)"
                    @onclick="() => ToggleGroup(group.Name)"
                    title="@group.Name">
                @GetGroupIcon(group.Name)
            </button>
        }
    </div>
</nav>

@if (_openGroupName != null)
{
    var openGroup = PhaseGroups.FirstOrDefault(g => g.Name == _openGroupName);
    if (openGroup != null)
    {
        <div class="nav-flyout-backdrop" @onclick="ClosePanel"></div>

        <div class="nav-flyout-panel">
            <div class="nav-flyout-header">
                <div>
                    <p class="nav-flyout-kicker">Phase @openGroup.PhaseNumber</p>
                    <strong class="nav-flyout-name">@openGroup.Name</strong>
                </div>
                <button class="nav-flyout-close" @onclick="ClosePanel" aria-label="Close panel">
                    @Icons.XMark
                </button>
            </div>

            <div class="nav-flyout-items">
                @foreach (var item in openGroup.Items)
                {
                    if (item.IsActive && item.Route != null)
                    {
                        <NavLink href="@item.Route"
                                 Match="NavLinkMatch.Prefix"
                                 class="sidebar-nav-link"
                                 ActiveClass="sidebar-nav-link-active"
                                 @onclick="ClosePanel">
                            <span class="sidebar-nav-icon">@item.Icon</span>
                            <span class="sidebar-nav-copy">
                                <span class="sidebar-nav-title">@item.Label</span>
                                <span class="sidebar-nav-summary">@GetItemDescription(item.Label)</span>
                            </span>
                            @if (item.Label == "Review Cards" && _dueCardCount > 0)
                            {
                                <span class="sidebar-item-badge">@_dueCardCount</span>
                            }
                        </NavLink>
                    }
                    else
                    {
                        <span class="sidebar-nav-link sidebar-nav-link-disabled">
                            <span class="sidebar-nav-icon">@item.Icon</span>
                            <span class="sidebar-nav-copy">
                                <span class="sidebar-nav-title">@item.Label</span>
                                <span class="sidebar-nav-summary">@GetItemDescription(item.Label)</span>
                            </span>
                            <span class="sidebar-item-badge">Soon</span>
                        </span>
                    }
                }
            </div>
        </div>
    }
}
