<article class="status-card">
    <div class="status-card-head">
        <div class="status-title">
            <strong>@Project.ProjectKey</strong>
            <p class="result-meta">@(Project.RunId is null ? "No active run" : $"Run {Project.RunId[..Math.Min(8, Project.RunId.Length)]}")</p>
        </div>
        <span class="status-pill @Project.Status.ToLowerInvariant()">@Project.Status</span>
    </div>

    <dl class="metric-list project-metrics">
        <div>
            <dt>Files</dt>
            <dd>@Project.TotalFiles</dd>
        </div>
        <div>
            <dt>Segments</dt>
            <dd>@Project.TotalSegments</dd>
        </div>
        <div>
            <dt>Updated</dt>
            <dd>@(Project.LastIndexedUtc?.ToLocalTime().ToString("g") ?? "Not indexed")</dd>
        </div>
        <div>
            <dt>Progress</dt>
            <dd>@Project.ProgressPercent.ToString("0.#")%</dd>
        </div>
    </dl>

    @if (Project.IndexingInProgress && Project.TotalFilesPlanned > 0)
    {
        <div class="progress-block">
            <div class="progress-head">
                <span>Processed @Project.FilesProcessed of @Project.TotalFilesPlanned files</span>
                <strong>@Project.ProgressPercent.ToString("0.#")%</strong>
            </div>
            <div class="progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@Project.ProgressPercent">
                <div class="progress-fill" style="width: @($"{Project.ProgressPercent:0.#}%");"></div>
            </div>
        </div>
    }

    @if (Project.IndexingInProgress && !string.IsNullOrWhiteSpace(Project.CurrentFilePath))
    {
        <p class="result-meta current-file">Current file: @Project.CurrentFilePath</p>
    }

    @if (Project.IndexingInProgress)
    {
        <p class="banner banner-warn">
            @(Project.CanResume
                ? "Indexing is paused for this workspace."
                : Project.Status == "Queued"
                    ? "This workspace is waiting in the queue."
                    : Project.TotalFilesPlanned == 0
                        ? "The worker is scanning project files."
                        : "Indexing is in progress for this workspace.")
        </p>
    }

    @if (Project.CanPause || Project.CanResume)
    {
        <div class="status-card-actions">
            @if (Project.CanPause)
            {
                <button class="button" @onclick="() => OnPauseRequested.InvokeAsync(Project.ProjectKey)">Pause</button>
            }
            @if (Project.CanResume)
            {
                <button class="button button-secondary" @onclick="() => OnResumeRequested.InvokeAsync(Project.ProjectKey)">Resume</button>
            }
        </div>
    }

    @if (Project.Status == "Failed")
    {
        <div class="status-card-actions">
            <button class="button" @onclick="() => OnRetryRequested.InvokeAsync(Project.ProjectKey)">Retry indexing</button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Project.LastError))
    {
        <p class="banner banner-error">@Project.LastError</p>
    }
</article>

@code {
    [Parameter, EditorRequired]
    public ProjectWorkspaceSummaryResponse Project { get; set; } = default!;

    [Parameter]
    public EventCallback<string> OnPauseRequested { get; set; }

    [Parameter]
    public EventCallback<string> OnResumeRequested { get; set; }

    [Parameter]
    public EventCallback<string> OnRetryRequested { get; set; }
}
