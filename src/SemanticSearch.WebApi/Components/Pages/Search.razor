@page "/search"
@inject NavigationManager NavigationManager

<PageTitle>Workspace</PageTitle>

<section class="card">
    <p class="empty-state">Search moved into the unified workspace. Redirecting to <a href="/workspace/search">Workspace</a>.</p>
</section>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            NavigationManager.NavigateTo("/workspace/search", replace: true);
        }
    }
}
