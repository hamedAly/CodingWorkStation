@page "/explorer"
@inject NavigationManager NavigationManager

<PageTitle>Workspace</PageTitle>

<section class="card">
    <p class="empty-state">Explorer moved into the unified workspace. Redirecting to <a href="/workspace/explorer">Workspace</a>.</p>
</section>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            NavigationManager.NavigateTo("/workspace/explorer", replace: true);
        }
    }
}
