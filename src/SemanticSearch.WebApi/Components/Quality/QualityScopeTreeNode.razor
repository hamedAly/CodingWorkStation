<div class="quality-scope-node">
    <div class="quality-scope-row">
        @if (HasChildren)
        {
            <button
                type="button"
                class="quality-scope-toggle"
                @onclick="ToggleExpanded"
                disabled="@Disabled">
                @(_isExpanded ? "▾" : "▸")
            </button>
        }
        else
        {
            <span class="quality-scope-toggle-placeholder"></span>
        }

        <input
            class="quality-scope-check"
            type="checkbox"
            checked="@IsSelected"
            @onchange="HandleCheckedChanged"
            disabled="@Disabled" />
        <span class="quality-scope-label">@Node.Name</span>
        <span class="quality-scope-badge">@NodeKindLabel</span>
    </div>

    @if (_isExpanded && HasChildren)
    {
        <div class="tree-children">
            @foreach (var child in Node.Children)
            {
                <QualityScopeTreeNode
                    Node="@child"
                    SelectedPath="@SelectedPath"
                    Disabled="@Disabled"
                    Depth="@(Depth + 1)"
                    OnScopeSelected="@OnScopeSelected" />
            }
        </div>
    }
</div>

@code {
    private bool _isExpanded;

    private bool IsProjectNode => Node.Path.Split('/', StringSplitOptions.RemoveEmptyEntries).Length == 1;
    private bool HasChildren => Node.Children.Count > 0;
    private bool IsSelected => string.Equals(SelectedPath ?? string.Empty, Node.Path, StringComparison.OrdinalIgnoreCase);
    private string NodeKindLabel => string.Equals(Node.NodeType, "File", StringComparison.OrdinalIgnoreCase)
        ? "File"
        : IsProjectNode
            ? "Project"
            : "Folder";

    [Parameter, EditorRequired]
    public ProjectTreeNodeResponse Node { get; set; } = default!;

    [Parameter]
    public string? SelectedPath { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public int Depth { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string> OnScopeSelected { get; set; }

    protected override void OnParametersSet()
    {
        if (Depth == 0 && HasChildren)
        {
            _isExpanded = true;
        }

        if (!string.IsNullOrWhiteSpace(SelectedPath) &&
            SelectedPath.StartsWith(Node.Path, StringComparison.OrdinalIgnoreCase) &&
            HasChildren)
        {
            _isExpanded = true;
        }
    }

    private void ToggleExpanded()
    {
        _isExpanded = !_isExpanded;
    }

    private Task HandleCheckedChanged(ChangeEventArgs args)
    {
        var isChecked = args.Value as bool? ?? false;
        return OnScopeSelected.InvokeAsync(isChecked ? Node.Path : string.Empty);
    }
}
