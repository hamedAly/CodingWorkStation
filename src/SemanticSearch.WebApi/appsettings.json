{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SemanticSearch": {
    "ModelPath": "models/all-MiniLM-L6-v2",
    "DatabasePath": "data/vectorstore.db",
    "Chunking": {
      "ChunkSize": 200,
      "Overlap": 40
    },
    "Ui": {
      "DashboardPollSeconds": 5,
      "DefaultSemanticTopK": 5,
      "DefaultExactTopK": 50
    },
    "Quality": {
      "MinimumStructuralLines": 5,
      "SemanticSimilarityThreshold": 0.9,
      "MaxSemanticPairs": 500,
      "MaxFindingsPerType": 100
    },
    "Integration": {
      "StandupCron": "30 9 * * MON-FRI",
      "PrayerFetchCron": "0 0 * * *",
      "DefaultPrayerMethod": 4,
      "TfsApiVersion": "7.1"
    },
    "Assistant": {
      "ModelPath": "models/llm/qwen2.5-coder-instruct.gguf",
      "ContextSize": 8192,
      "MaxTokens": 2048,
      "CpuThreads": 8,
      "GpuLayerCount": 0,
      "AntiPrompts": [
        "User:",
        "System:",
        "<|im_end|>"
      ],
      "MaxDuplicateSnippetCharacters": 12000,
      "Temperature": 0.2,
      "StartupMode": "MarkUnavailable"
    },
    "Indexing": {
      "ExcludedDirectories": [
        "bin", "obj", ".git", ".vs", ".venv", "node_modules", "packages",
        "dist", "build", "target", "coverage", "out", "debug", "release"
      ],
      "AllowedExtensions": [
        ".cs", ".ts", ".tsx", ".js", ".jsx",
        ".py", ".rb", ".go", ".rs", ".java",
        ".cpp", ".c", ".h", ".hpp",
        ".md", ".txt", ".json", ".yaml", ".yml",
        ".xml", ".html", ".css", ".sql", ".razor"
      ]
    }
  }
}
